cat <<'EOF' > .gitignore
# =========================
# 🔐 SECRETS / ENV
# =========================
.env
*.env

# =========================
# 🧠 LOCAL CONFIG
# =========================
config.json
.spotiflopy_config.json

# =========================
# 💾 DATABASES
# =========================
*.db
*.db-shm
*.db-wal

# =========================
# 🧠 CACHE / TOKENS
# =========================
.cache
cache/
*.cache.json
.spotiflopy_cache*
.spotiflopy_token_cache*

# =========================
# 🍪 COOKIES
# =========================
cookies.txt
cookies.spotiflopy.db

# =========================
# 🐍 PYTHON
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# 🧪 VIRTUAL ENVS
# =========================
myenv/
venv/

# =========================
# 📦 BUILD ARTIFACTS
# =========================
build/
dist/
*.egg-info/

# =========================
# 🎵 DOWNLOADS / MEDIA
# =========================
downloads/
Music/
*.mp3
*.webm
*.m4a

# =========================
# 🧾 LOGS
# =========================
*.log

# =========================
# 💻 IDE
# =========================
.vscode/
.idea/

# =========================
# 🖥️ OS JUNK
# =========================
.DS_Store
Thumbs.db

# =========================
# 📚 DOCS
# =========================
docs/
docs/info.md

# =========================
# 🧯 BACKUPS / TEMP
# =========================
*.bak
*.tmp
*.swp

# =========================
# 📦 NODE (optional)
# =========================
node_modules/
EOF
# =========================
# 🧾 JSON DATA DUMPS (ignore all except examples)
# =========================
*.json
!config.example.json
!.pre-commit-config.yaml
!.secrets.baseline
